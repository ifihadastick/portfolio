---
interface Props {
  number: string;
  title: string;
}
const { number, title } = Astro.props;
---

<div class="reveal mb-10 flex items-baseline gap-4 px-3">
  <span class="section-number text-sm font-bold sm:text-base">{number}</span>
  <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">{title}</h2>
  <div class="ml-2 hidden h-px flex-1 bg-gradient-to-r from-white/15 to-transparent sm:block"></div>
</div>
