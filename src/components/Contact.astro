---
import SectionHeading from './SectionHeading.astro';
import { profile } from '../data/content';
---

<section id="contact" class="mx-auto max-w-5xl px-6 py-16">
  <SectionHeading number="08" title="Contact" />
  <div
    class="reveal relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-8 text-center sm:p-14"
  >
    <div
      class="pointer-events-none absolute inset-x-0 -top-24 mx-auto h-48 w-2/3 rounded-full bg-teal-500/20 blur-3xl"
    ></div>
    <div class="relative">
      <h3 class="font-display text-2xl font-bold text-white sm:text-3xl">Let's build something.</h3>
      <p class="mx-auto mt-3 max-w-md text-base text-slate-400">
        Open to conversations about AI infrastructure, analytics, and enterprise technology
        strategy.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href={`mailto:${profile.email}`} class="btn btn-primary">{profile.email}</a>
        <a href={profile.linkedin} target="_blank" rel="noopener" class="btn btn-ghost">LinkedIn</a>
        <a href={profile.github} target="_blank" rel="noopener" class="btn btn-ghost">GitHub</a>
      </div>
      <p class="mt-6 text-sm text-slate-500">{profile.phone} · {profile.location}</p>
    </div>
  </div>
</section>
