---
import SectionHeading from './SectionHeading.astro';
import { profile } from '../data/content';
---

<section id="contact" class="mx-auto max-w-5xl px-6 py-16">
  <SectionHeading number="09" title="Contact" />
  <div class="rounded-lg border border-slate-200 p-8 text-center sm:p-12">
    <p class="text-base text-slate-600">
      Open to conversations about AI infrastructure, analytics, and Higher Ed / SLED technology
      strategy.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-4">
      <a
        href={`mailto:${profile.email}`}
        class="rounded-md bg-ink px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent-dark"
      >
        {profile.email}
      </a>
      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener"
        class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-accent-dark hover:text-accent-dark"
      >
        LinkedIn
      </a>
      <a
        href={profile.github}
        target="_blank"
        rel="noopener"
        class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-accent-dark hover:text-accent-dark"
      >
        GitHub
      </a>
    </div>
    <p class="mt-6 text-sm text-slate-500">{profile.phone} · {profile.location}</p>
  </div>
</section>
