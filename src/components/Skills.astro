---
import SectionHeading from './SectionHeading.astro';
import { skillGroups } from '../data/content';
---

<section id="skills" class="mx-auto max-w-5xl px-6 py-16">
  <SectionHeading number="03" title="Skills" />
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {skillGroups.map((group) => (
      <div class="rounded-lg border border-slate-200 p-5">
        <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-accent-dark">
          {group.category}
        </h3>
        <ul class="flex flex-wrap gap-2">
          {group.items.map((item) => (
            <li class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-700">
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
