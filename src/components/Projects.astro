---
import Collapsible from './Collapsible.astro';
import { projects, profile } from '../data/content';
const base = import.meta.env.BASE_URL;
---

<section id="projects" class="mx-auto max-w-5xl px-6 py-2">
  <Collapsible number="05" title="Projects">
    <div class="grid gap-6 sm:grid-cols-2">
      {projects.map((project) => (
        <div class="flex flex-col rounded-lg border border-slate-200 p-6">
          <div class="flex items-baseline justify-between gap-2">
            <h3 class="text-lg font-bold text-ink">{project.title}</h3>
            <span class="whitespace-nowrap text-xs text-slate-500">{project.date}</span>
          </div>
          <p class="mt-1 text-xs font-medium uppercase tracking-wide text-accent-dark">
            {project.org}
          </p>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">{project.description}</p>
          {project.metrics.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-2">
              {project.metrics.map((metric) => (
                <li class="rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold text-accent-dark">
                  {metric}
                </li>
              ))}
            </ul>
          )}
          <ul class="mt-4 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <li class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-700">{tag}</li>
            ))}
          </ul>
          {project.links.length > 0 && (
            <div class="mt-4 flex gap-4">
              {project.links.map((link) => (
                <a
                  href={link.url.startsWith('/') ? `${base}${link.url.slice(1)}` : link.url}
                  target="_blank"
                  rel="noopener"
                  class="text-sm font-semibold text-accent-dark hover:underline"
                >
                  {link.label} →
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
    <p class="mt-8 text-sm text-slate-500">
      More projects on
      <a href={profile.linkedin} target="_blank" rel="noopener" class="font-semibold text-accent-dark hover:underline">
        LinkedIn
      </a>.
    </p>
  </Collapsible>
</section>
