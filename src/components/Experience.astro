---
import Collapsible from './Collapsible.astro';
import { experience } from '../data/content';
---

<section id="experience" class="mx-auto max-w-5xl px-6 py-2">
  <Collapsible number="02" title="Experience">
    <div class="space-y-10">
      {experience.map((job) => (
        <div class="grid gap-2 sm:grid-cols-4 sm:gap-8">
          <div class="sm:col-span-1">
            <p class="text-sm font-semibold text-ink">{job.dates}</p>
            <p class="text-sm text-slate-500">{job.location}</p>
          </div>
          <div class="sm:col-span-3">
            <h3 class="text-lg font-bold text-ink">
              {job.role} <span class="font-normal text-slate-500">· {job.company}</span>
            </h3>
            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-slate-600">
              {job.bullets.map((bullet) => (
                <li class="flex gap-2">
                  <span class="text-accent-dark">▸</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </Collapsible>
</section>
