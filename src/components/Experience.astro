---
import Collapsible from './Collapsible.astro';
import { experience } from '../data/content';
---

<section id="experience" class="mx-auto max-w-5xl px-6 py-2">
  <Collapsible number="02" title="Experience">
    <div class="space-y-4">
      {experience.map((job) => (
        <div class="card reveal grid gap-3 p-6 sm:grid-cols-4 sm:gap-8">
          <div class="sm:col-span-1">
            <p class="text-sm font-semibold text-teal-300">{job.dates}</p>
            <p class="text-sm text-slate-500">{job.location}</p>
          </div>
          <div class="sm:col-span-3">
            <h3 class="text-lg font-bold text-white">
              {job.role} <span class="font-normal text-slate-400">· {job.company}</span>
            </h3>
            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-slate-400">
              {job.bullets.map((bullet) => (
                <li class="flex gap-2.5">
                  <span class="mt-0.5 text-teal-400">▸</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </Collapsible>
</section>
