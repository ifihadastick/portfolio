---
import Collapsible from './Collapsible.astro';
import { publications } from '../data/content';
---

<section id="publications" class="mx-auto max-w-5xl px-6 py-2">
  <Collapsible number="06" title="Publications">
    <div class="space-y-6">
      {publications.map((pub) => (
        <div class="rounded-lg border border-slate-200 p-6">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-lg font-bold text-ink">{pub.title}</h3>
            <span class="text-xs text-slate-500">{pub.year}</span>
          </div>
          <p class="mt-1 text-sm font-medium text-accent-dark">{pub.venue}</p>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{pub.description}</p>
          <div class="mt-3 flex gap-4">
            {pub.links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener"
                class="text-sm font-semibold text-accent-dark hover:underline"
              >
                {link.label} →
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Collapsible>
</section>
