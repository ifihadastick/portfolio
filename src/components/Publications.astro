---
import Collapsible from './Collapsible.astro';
import { publications } from '../data/content';
---

<section id="publications" class="mx-auto max-w-5xl px-6 py-2">
  <Collapsible number="06" title="Publications">
    <div class="space-y-4">
      {publications.map((pub) => (
        <div class="card reveal p-6">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-lg font-bold text-white">{pub.title}</h3>
            <span class="text-xs text-slate-500">{pub.year}</span>
          </div>
          <div class="mt-1 flex flex-wrap items-center gap-2">
            <p class="text-sm font-medium text-teal-300">{pub.venue}</p>
            <span class="rounded-full border border-white/10 bg-white/5 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-slate-400">
              {pub.type}
            </span>
          </div>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{pub.description}</p>
          <div class="mt-3 flex gap-4">
            {pub.links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener"
                class="text-sm font-semibold text-teal-300 transition hover:text-teal-200 hover:underline"
              >
                {link.label} →
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Collapsible>
</section>
