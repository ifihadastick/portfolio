---
const nav = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#education', label: 'Education' },
  { href: '#projects', label: 'Projects' },
  { href: '#publications', label: 'Publications' },
  { href: '#work', label: 'Live Work' },
  { href: '#awards', label: 'Awards' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-paper/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="#" class="text-sm font-bold tracking-widest text-ink">JS</a>
    <nav class="hidden gap-6 text-sm text-slate-600 md:flex">
      {nav.map((item) => (
        <a href={item.href} class="transition hover:text-accent-dark">
          {item.label}
        </a>
      ))}
    </nav>
    <button
      id="nav-toggle"
      class="text-sm text-slate-600 md:hidden"
      aria-label="Toggle navigation"
    >
      Menu
    </button>
  </div>
  <nav id="nav-mobile" class="hidden flex-col gap-4 border-t border-slate-200/70 px-6 py-4 text-sm text-slate-600 md:hidden">
    {nav.map((item) => (
      <a href={item.href} class="block py-1 transition hover:text-accent-dark">
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
    })
  );
</script>
