---
import SectionHeading from './SectionHeading.astro';
import { liveWork, dashboards } from '../data/content';
---

<section id="work" class="mx-auto max-w-5xl px-6 py-16">
  <SectionHeading number="07" title="Live Work" />

  <div class="grid gap-6 sm:grid-cols-2">
    {liveWork.map((item) => (
      <div class="flex flex-col rounded-lg border border-slate-200 p-6">
        <h3 class="text-lg font-bold text-ink">{item.title}</h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">{item.description}</p>
        <a
          href={item.url}
          target="_blank"
          rel="noopener"
          class="mt-4 text-sm font-semibold text-accent-dark hover:underline"
        >
          {item.cta} →
        </a>
      </div>
    ))}
  </div>

  <h3 class="mb-4 mt-12 text-sm font-semibold uppercase tracking-wide text-slate-500">
    Power BI Dashboards — SLED Market Intelligence
  </h3>
  <div class="space-y-10">
    {dashboards.map((dash) => (
      <div>
        <p class="mb-2 text-sm font-medium text-ink">{dash.title}</p>
        <div class="overflow-hidden rounded-lg border border-slate-200">
          <iframe
            title={dash.title}
            src={dash.url}
            class="aspect-video w-full"
            loading="lazy"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    ))}
  </div>
</section>
