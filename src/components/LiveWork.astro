---
import Collapsible from './Collapsible.astro';
import { liveWork, dashboards } from '../data/content';
---

<section id="work" class="mx-auto max-w-5xl px-6 py-2">
  <Collapsible number="07" title="Live Work">
    <div class="grid gap-5 sm:grid-cols-2">
      {liveWork.map((item) => (
        <div class="card reveal flex flex-col p-6">
          <h3 class="text-lg font-bold text-white">{item.title}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400">{item.description}</p>
          <a
            href={item.url}
            target="_blank"
            rel="noopener"
            class="mt-4 text-sm font-semibold text-teal-300 transition hover:text-teal-200 hover:underline"
          >
            {item.cta} →
          </a>
        </div>
      ))}
    </div>

    <h3 class="reveal mb-4 mt-12 text-sm font-semibold uppercase tracking-wider text-slate-500">
      Power BI Dashboards
    </h3>
    <div class="space-y-8">
      {dashboards.map((dash) => (
        <div class="reveal">
          <p class="mb-2 text-sm font-medium text-slate-200">{dash.title}</p>
          <div class="overflow-hidden rounded-xl border border-white/10 bg-white/[0.02]">
            <iframe
              title={dash.title}
              src={dash.url}
              class="aspect-video w-full"
              loading="lazy"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      ))}
    </div>
  </Collapsible>
</section>
