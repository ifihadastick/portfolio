---
import { profile } from '../data/content';
---

<section class="mx-auto flex max-w-5xl flex-col gap-10 px-6 pb-20 pt-16 sm:pt-24">
  <div class="max-w-3xl">
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent-dark">
      {profile.location}
    </p>
    <h1 class="text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">
      {profile.name}
    </h1>
    <p class="mt-3 text-lg font-medium text-slate-600 sm:text-xl">{profile.title}</p>
    <p class="mt-6 max-w-2xl text-base leading-relaxed text-slate-600">
      {profile.summary}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener"
        class="rounded-md bg-ink px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent-dark"
      >
        LinkedIn
      </a>
      <a
        href="#projects"
        class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-accent-dark hover:text-accent-dark"
      >
        View Work ↓
      </a>
      <a
        href="#contact"
        class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-accent-dark hover:text-accent-dark"
      >
        Get in Touch →
      </a>
    </div>
  </div>
</section>
